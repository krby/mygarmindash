# Copy to .env and fill in. .env is git-ignored.

# Use the https:// scheme, NOT libsql:// 
# the Python libsql-client's websocket (wss://) transport fails on some setups (e.g. Windows) with a 400 handshake error. 
# `turso db show <db> --url` prints libsql://[url] so rewrite it to https://[url]
TURSO_URL=https://your-db-name.turso.io
TURSO_AUTH_TOKEN=<paste turso db tokens create output>

# Optional. Defaults to ~/.garmin-givemydata.
# GARMIN_DATA_DIR=C:\Users\<you>\.garmin-givemydata
